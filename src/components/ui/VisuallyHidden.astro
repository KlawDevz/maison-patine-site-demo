---
/**
 * Composant pour texte accessible uniquement aux lecteurs d'écran
 */
---

<span class="visually-hidden">
  <slot />
</span>

<style>
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>