---
type GalleryCategory =
  | "facade"
  | "ambiance"
  | "mise-en-scene"
  | "details"
  | "objets"
  | "ensemble";

type Item = {
  src: string;
  alt: string;
  category?: GalleryCategory;
  srcSet?: string;
  sizes?: string;
};

type Props = {
  items: Item[];
};

const galleryGridId = "gallery-grid";

type CategoryOption = {
  key: GalleryCategory;
  label: string;
};

const categoryOptions: CategoryOption[] = [
  { key: "facade", label: "Façade / Extérieur" },
  { key: "ambiance", label: "Ambiance intérieure" },
  { key: "mise-en-scene", label: "Mises en scène" },
  { key: "details", label: "Détails déco" },
  { key: "objets", label: "Objets et pièces" },
  { key: "ensemble", label: "Vues d'ensemble" }
];

const categoryLabelByKey = categoryOptions.reduce<Record<GalleryCategory, string>>((acc, category) => {
  acc[category.key] = category.label;
  return acc;
}, {} as Record<GalleryCategory, string>);

const { items } = Astro.props as Props;

const buildSrcSet = (src: string) => {
  if (!src.endsWith(".webp")) {
    return `${src} 600w`;
  }

  const base = src.slice(0, -5);
  return `${base}-600.webp 600w, ${base}-900.webp 900w, ${src} 1600w`;
};

const normalizedItems: Item[] = items.map((item) => ({
  ...item,
  category: item.category ?? "ambiance",
  srcSet: buildSrcSet(item.src),
  sizes: item.sizes ?? "(max-width: 640px) 100vw, (max-width: 900px) 50vw, 33vw"
}));

const realCountByCategory = categoryOptions.reduce<Record<GalleryCategory, number>>((acc, category) => {
  acc[category.key] = normalizedItems.filter((item) => item.category === category.key).length;
  return acc;
}, {} as Record<GalleryCategory, number>);

const placeholders: Item[] = categoryOptions
  .filter((category) => realCountByCategory[category.key] === 0)
  .map((category) => ({
    src: "",
    alt: `Photo à venir - ${category.label}`,
    category: category.key,
    srcSet: "",
    sizes: ""
  }));

const displayItems: Item[] = [...normalizedItems, ...placeholders];
---

<section id="galerie" class="section-shell" aria-labelledby="gallery-title">
  <div class="flex flex-wrap items-center justify-between gap-4">
    <h2 id="gallery-title" class="section-title">Par catégories</h2>
    <p class="text-sm uppercase tracking-[0.08em] text-[color:var(--ink-500)]">Sélection évolutive par univers</p>
  </div>

  <div class="gallery-toolbar mt-5 flex flex-wrap gap-2" role="toolbar" aria-label="Filtrer la galerie par catégorie">
    <button class="gallery-filter is-active" type="button" data-filter="all" aria-controls={galleryGridId} aria-pressed="true">
      Tout <span class="opacity-70">({displayItems.length})</span>
    </button>
    {categoryOptions.map((category) => (
      <button class="gallery-filter" type="button" data-filter={category.key} aria-controls={galleryGridId} aria-pressed="false">
        {category.label}{" "}
        {realCountByCategory[category.key] > 0 ? (
          <span class="opacity-70">({realCountByCategory[category.key]})</span>
        ) : (
          <span class="gallery-soon">Photo à venir</span>
        )}
      </button>
    ))}
  </div>

  <p class="mt-3 text-sm text-[color:var(--ink-500)]" data-filter-status aria-live="polite">
    Affichage de {displayItems.length} visuels sur {displayItems.length}.
  </p>

  <div id={galleryGridId} class="gallery-grid mt-8 grid gap-5 sm:grid-cols-2 md:grid-cols-3" data-gallery-grid>
    {displayItems.map((item, index) => {
      const categoryLabel = item.category ? categoryLabelByKey[item.category] : "Catégorie";

      return (
        <figure
          class={`gallery-item overflow-hidden border border-[color:var(--line)] bg-[color:var(--bg-alt)] ${item.src ? "" : "gallery-item--placeholder"}`}
          data-gallery-item
          data-category={item.category}
        >
          {item.src ? (
            <img
              src={item.src}
              srcset={item.srcSet}
              sizes={item.sizes}
              alt={item.alt}
              loading={index === 0 ? "eager" : "lazy"}
              width="600"
              height="400"
              class="gallery-img h-52 w-full object-cover md:h-64"
              decoding={index === 0 ? "sync" : "async"}
            />
          ) : (
            <div class="gallery-placeholder flex h-52 w-full flex-col items-center justify-center md:h-64">
              <img src="/images/logo.png" alt="" width="34" height="34" class="gallery-placeholder-logo" loading="lazy" />
              <span class="mt-2 text-xs uppercase tracking-[0.08em] text-[color:var(--ink-500)]">Photo à venir</span>
            </div>
          )}
          <figcaption class="gallery-caption border-t border-[color:var(--line)] px-3 py-2 text-sm text-[color:var(--ink-700)]">
            {categoryLabel}
          </figcaption>
        </figure>
      );
    })}
  </div>

  <p class="mt-4 text-center text-sm text-[color:var(--ink-500)]">
    {placeholders.length > 0 && `+${placeholders.length} catégories avec photos à venir`}
  </p>
</section>

<script>
  const categoryLabelByKey: Record<string, string> = {
    facade: "Façade / Extérieur",
    ambiance: "Ambiance intérieure",
    "mise-en-scene": "Mises en scène",
    details: "Détails déco",
    objets: "Objets et pièces",
    ensemble: "Vues d'ensemble"
  };

  const filterButtons = Array.from(document.querySelectorAll<HTMLButtonElement>(".gallery-filter"));
  const galleryItems = Array.from(document.querySelectorAll<HTMLElement>("[data-gallery-item]"));
  const filterStatus = document.querySelector<HTMLElement>("[data-filter-status]");
  const validFilters = new Set(["all", ...Object.keys(categoryLabelByKey)]);

  const totalCount = galleryItems.length;

  const applyFilter = (filter: string, options?: { syncUrl?: boolean }) => {
    const normalizedFilter = validFilters.has(filter) ? filter : "all";
    let visibleCount = 0;

    galleryItems.forEach((item) => {
      const category = item.dataset.category;
      const shouldShow = normalizedFilter === "all" || category === normalizedFilter;
      item.classList.toggle("hidden", !shouldShow);

      if (shouldShow) {
        visibleCount += 1;
      }
    });

    filterButtons.forEach((button) => {
      const isActive = button.dataset.filter === normalizedFilter;
      button.classList.toggle("is-active", isActive);
      button.setAttribute("aria-pressed", isActive ? "true" : "false");
    });

    if (filterStatus) {
      const filterLabel = normalizedFilter === "all" ? "Toutes catégories" : (categoryLabelByKey[normalizedFilter] ?? "Catégorie");
      filterStatus.textContent = `Affichage de ${visibleCount} visuels sur ${totalCount} - ${filterLabel}.`;
    }

    if (options?.syncUrl) {
      const url = new URL(window.location.href);
      if (normalizedFilter === "all") {
        url.searchParams.delete("filter");
      } else {
        url.searchParams.set("filter", normalizedFilter);
      }
      window.history.pushState({}, "", url);
    }
  };

  filterButtons.forEach((button) => {
    button.addEventListener("click", () => {
      applyFilter(button.dataset.filter ?? "all", { syncUrl: true });
    });
  });

  const initialFilter = new URLSearchParams(window.location.search).get("filter") ?? "all";
  applyFilter(initialFilter);

  window.addEventListener("popstate", () => {
    const popstateFilter = new URLSearchParams(window.location.search).get("filter") ?? "all";
    applyFilter(popstateFilter);
  });
</script>

<style>
  .gallery-img {
    transition: transform 0.6s ease;
  }

  .gallery-grid {
    position: relative;
  }

  .gallery-grid::before {
    content: "";
    position: absolute;
    inset: -0.6rem;
    z-index: -1;
    background: radial-gradient(circle at 10% 12%, rgba(176, 139, 87, 0.12), transparent 38%);
    pointer-events: none;
  }

  .gallery-item:hover .gallery-img {
    transform: scale(1.03);
  }

  .gallery-item {
    border-radius: 2px;
    transition: border-color 0.35s ease, transform 0.35s ease, box-shadow 0.35s ease;
    box-shadow: 0 8px 16px rgba(43, 32, 24, 0.05);
  }

  .gallery-item:hover {
    border-color: color-mix(in oklab, var(--line) 70%, var(--brand) 30%);
    transform: translateY(-3px);
    box-shadow: 0 14px 24px rgba(43, 32, 24, 0.1);
  }

  .gallery-item--placeholder {
    border-style: dashed;
  }

  .gallery-placeholder {
    background: color-mix(in oklab, var(--surface) 84%, var(--bg-main) 16%);
  }

  .gallery-placeholder-logo {
    display: block;
    width: 2rem;
    height: 2rem;
    object-fit: contain;
    opacity: 0.78;
    filter: saturate(0.55) sepia(0.25);
  }

  .gallery-filter {
    border: 1px solid color-mix(in oklab, var(--line) 75%, var(--ink-500) 25%);
    border-radius: 2px;
    padding: 0.55rem 0.9rem;
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-700);
    background: color-mix(in oklab, var(--bg-alt) 90%, #fff 10%);
    transition: border-color 0.3s ease, color 0.3s ease, background-color 0.3s ease;
    min-height: 44px;
    touch-action: manipulation;
    -webkit-tap-highlight-color: rgba(139, 47, 47, 0.16);
  }

  .gallery-filter:focus-visible {
    outline: 2px solid var(--brand);
    outline-offset: 2px;
  }

  .gallery-filter:hover {
    border-color: color-mix(in oklab, var(--line) 55%, var(--brand) 45%);
    color: var(--ink-900);
  }

  .gallery-filter.is-active {
    border-color: var(--brand);
    background: color-mix(in oklab, var(--bg-alt) 90%, var(--brand) 10%);
    color: var(--brand-soft);
    font-weight: 600;
    box-shadow: 0 4px 12px rgba(43, 32, 24, 0.08);
  }

  .gallery-toolbar {
    border-top: 1px solid color-mix(in oklab, var(--line) 70%, transparent);
    padding-top: 0.8rem;
  }

  @media (prefers-reduced-motion: reduce) {
    .gallery-item,
    .gallery-img,
    .gallery-filter {
      transition: none;
    }
  }

  .gallery-soon {
    border: 1px solid color-mix(in oklab, var(--line) 80%, var(--ink-500) 20%);
    border-radius: 2px;
    margin-left: 0.25rem;
    padding: 0.05rem 0.45rem;
    font-size: 0.7rem;
    color: var(--ink-500);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: color-mix(in oklab, var(--bg-alt) 94%, var(--surface) 6%);
    white-space: normal;
    text-wrap: balance;
  }

  .gallery-caption {
    font-family: var(--font-display);
    font-size: 1.05rem;
    line-height: 1.25;
    text-wrap: balance;
    background: color-mix(in oklab, var(--bg-alt) 88%, #fff 12%);
  }

  @media (prefers-reduced-motion: no-preference) {
    .gallery-item {
      animation: gallery-fade-in 0.8s ease-out both;
    }

    .gallery-item:nth-child(2) {
      animation-delay: 0.04s;
    }

    .gallery-item:nth-child(3) {
      animation-delay: 0.08s;
    }
  }

  @keyframes gallery-fade-in {
    from {
      opacity: 0;
      transform: translateY(8px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
