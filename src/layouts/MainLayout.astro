---
import "../styles/global.css";
import MainNav from "../components/navigation/MainNav.astro";
import SiteFooter from "../components/navigation/SiteFooter.astro";
import SkipLink from "../components/navigation/SkipLink.astro";
import { siteData } from "../data/site";

type Props = {
  title?: string;
  description?: string;
  canonicalPath?: string;
  ogImage?: string;
  noindex?: boolean;
};

const {
  title = "Maison Patine - Brocante, Décoration, Artisanat",
  description = "Site vitrine V1 de Maison Patine à Mirepoix.",
  canonicalPath = "/",
  ogImage,
  noindex = false
} = Astro.props as Props;

const canonicalUrl = new URL(canonicalPath, Astro.url).toString();
const ogImageUrl = new URL(ogImage ?? "/images/devanture_magasinV2.webp", Astro.url).toString();
const itineraryUrl = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(siteData.common.address)}`;
const whatsappDigits = siteData.common.phoneHref.replace(/\D/g, "");
const whatsappUrl = `https://wa.me/${whatsappDigits}`;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow, max-image-preview:large"} />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta name="geo.region" content="FR-09" />
    <meta name="geo.placename" content={siteData.common.city} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href="https://fonts.gstatic.com/s/manrope/v20/xn7gYHE41ni1AdIRggexSg.woff2"
      crossorigin="anonymous"
    />
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href="https://fonts.gstatic.com/s/fraunces/v38/6NU78FyLNQOQZAnv9bYEvDiIdE9Ea92uemAk_WBq8U_9v0c2Wa0KxC9TeA.woff2"
      crossorigin="anonymous"
    />
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href="https://fonts.gstatic.com/s/cormorantgaramond/v21/co3bmX5slCNuHLi8bLeY9MK7whWMhyjYqXtK.woff2"
      crossorigin="anonymous"
    />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=Manrope:wght@400;500;600;700&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=Manrope:wght@400;500;600;700&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=Manrope:wght@400;500;600;700&display=swap"
      />
    </noscript>
    
    <!-- Favicon et App -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <link rel="manifest" href="/site.webmanifest" />
    
    <!-- SEO Canonique -->
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="fr-FR" href={canonicalUrl} />
    <link rel="alternate" hreflang="x-default" href={canonicalUrl} />
    
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Maison Patine" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:type" content="image/webp" />
    <meta property="og:image:alt" content="Devanture de la boutique Maison Patine à Mirepoix" />
    
    <!-- Twitter Cards -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    
    <!-- Theme Color -->
    <meta name="theme-color" content="#3B2F24" />
    
    <title>{title}</title>
  </head>
  <body class="min-h-screen antialiased has-mobile-dock">
    <SkipLink />
    <MainNav />
    <slot />
    <SiteFooter />
    <div class="mobile-cta-dock" role="region" aria-label="Actions rapides">
      <a class="mobile-cta-dock__link mobile-cta-dock__link--primary" href={siteData.common.phoneHref}>
        <span class="mobile-cta-dock__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.12.89.32 1.76.6 2.6a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.48-1.17a2 2 0 0 1 2.11-.45c.84.28 1.71.48 2.6.6A2 2 0 0 1 22 16.92z" />
          </svg>
        </span>
        <span class="mobile-cta-dock__text">Appeler</span>
      </a>
      <a
        class="mobile-cta-dock__link mobile-cta-dock__link--whatsapp"
        href={whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`Contacter ${siteData.common.brand} sur WhatsApp (nouvel onglet)`}
      >
        <span class="mobile-cta-dock__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.52 3.48A11.86 11.86 0 0 0 12.07 0C5.53 0 .21 5.32.21 11.86c0 2.09.55 4.14 1.59 5.95L0 24l6.39-1.68a11.84 11.84 0 0 0 5.68 1.45h.01c6.54 0 11.86-5.32 11.86-11.86 0-3.17-1.23-6.14-3.42-8.43Zm-8.45 18.29h-.01a9.87 9.87 0 0 1-5.03-1.38l-.36-.22-3.79 1 1.01-3.7-.23-.38a9.86 9.86 0 0 1-1.5-5.23c0-5.45 4.43-9.88 9.89-9.88 2.64 0 5.12 1.03 6.98 2.89a9.83 9.83 0 0 1 2.9 6.99c0 5.46-4.43 9.89-9.86 9.89Zm5.42-7.42c-.3-.15-1.78-.88-2.06-.98-.28-.1-.48-.15-.68.15-.2.3-.78.98-.95 1.18-.17.2-.35.23-.65.08-.3-.15-1.26-.46-2.4-1.46-.89-.79-1.49-1.76-1.66-2.06-.17-.3-.02-.46.13-.61.13-.13.3-.35.45-.53.15-.18.2-.3.3-.5.1-.2.05-.38-.03-.53-.08-.15-.68-1.64-.93-2.24-.24-.58-.49-.5-.68-.51h-.58c-.2 0-.53.08-.8.38-.28.3-1.06 1.04-1.06 2.54 0 1.5 1.09 2.95 1.24 3.15.15.2 2.14 3.26 5.18 4.57.72.31 1.28.5 1.72.64.72.23 1.37.2 1.88.12.57-.08 1.78-.73 2.03-1.43.25-.7.25-1.3.18-1.43-.08-.13-.28-.2-.58-.35Z" />
          </svg>
        </span>
        <span class="mobile-cta-dock__text">WhatsApp</span>
      </a>
      <a
        class="mobile-cta-dock__link mobile-cta-dock__link--route"
        href={itineraryUrl}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`Ouvrir l'itinéraire vers ${siteData.common.brand} dans Google Maps (nouvel onglet)`}
      >
        <span class="mobile-cta-dock__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
            <circle cx="12" cy="10" r="3" />
          </svg>
        </span>
        <span class="mobile-cta-dock__text">Itinéraire</span>
      </a>
    </div>
    <script is:inline>
      (() => {
        const getOpenStatusLabel = () => {
          const nowInParis = new Date(new Date().toLocaleString("en-US", { timeZone: "Europe/Paris" }));
          const day = nowInParis.getDay();
          const minutes = nowInParis.getHours() * 60 + nowInParis.getMinutes();
          const isOpenDay = day >= 2 && day <= 6;
          const isOpenTime = minutes >= 600 && minutes <= 1110;
          const isOpen = isOpenDay && isOpenTime;

          return isOpen
            ? "Ouvert aujourd'hui jusqu'à 18h30"
            : "Fermé actuellement · Mardi au samedi 10h00 - 18h30";
        };

        const openStatus = getOpenStatusLabel();
        const openStatusTargets = document.querySelectorAll("[data-open-status]");
        openStatusTargets.forEach((target) => {
          target.textContent = openStatus;
        });

        const revealTargets = Array.from(document.querySelectorAll(".reveal:not(.home-reveal)"));

        if (revealTargets.length === 0) {
          return;
        }

        const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

        if (prefersReducedMotion || !("IntersectionObserver" in window)) {
          revealTargets.forEach((target) => target.classList.add("is-visible"));
          return;
        }

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.12 }
        );

        revealTargets.forEach((target, index) => {
          if (!target.getAttribute("style")?.includes("transition-delay")) {
            target.setAttribute("style", `${target.getAttribute("style") ?? ""}; transition-delay:${index * 80}ms`);
          }
          observer.observe(target);
        });
      })();
    </script>
  </body>
</html>
