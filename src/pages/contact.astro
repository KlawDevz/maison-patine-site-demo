---
import MainLayout from "../layouts/MainLayout.astro";
import { siteData } from "../data/site";

const itineraryQuery = encodeURIComponent(siteData.common.address);
const itineraryUrl = `https://www.google.com/maps/search/?api=1&query=${itineraryQuery}`;
const embeddedMapUrl = `https://www.google.com/maps?q=${itineraryQuery}&output=embed`;

const hasAddress = Boolean(siteData.common.address?.trim());
const hasPhone = Boolean(siteData.common.phoneDisplay?.trim() && siteData.common.phoneHref?.trim());
const hasEmail = Boolean(siteData.common.email?.trim());
const hasInstagram = Boolean(siteData.common.social.instagramUrl?.trim() && siteData.common.social.instagramLabel?.trim());
const hasFacebook = Boolean(siteData.common.social.facebookUrl?.trim() && siteData.common.social.facebookLabel?.trim());
---

<MainLayout
  title={siteData.metaByPage.contact.title}
  description={siteData.metaByPage.contact.description}
  canonicalPath={siteData.metaByPage.contact.canonicalPath}
>
  <main id="main-content" class="contact-page mx-auto w-full max-w-[1240px] px-6 py-10 md:py-20 xl:px-8 xl:py-24">
    <div class:list={["contact-grid", hasAddress && "has-map"]}>
      <section class="section-shell da-panel reveal" aria-labelledby="contact-page-title">
        <header>
          <p class="contact-kicker da-eyebrow">Maison Patine</p>
          <p class="da-ornament">Contact & rendez-vous</p>
          <h1 id="contact-page-title" class="contact-title">Contact</h1>
          <p class="contact-intro">
            Pour toute demande d'information ou pour découvrir l'univers de Maison Patine, vous pouvez nous contacter ou
            venir en boutique.
          </p>
          <p class="open-status" data-open-status aria-live="polite">Horaires en cours de chargement…</p>
          <p class="local-proof">Boutique locale à Mirepoix (Ariège), au cœur du centre historique.</p>
          <p class="da-star" aria-hidden="true"></p>
        </header>

        <div class="contact-cards">
          {hasPhone && (
            <article class="reveal contact-card da-panel">
              <p class="card-label">Téléphone</p>
              <p class="card-value phone-value">{siteData.common.phoneDisplay}</p>
              <p class="card-copy">Échange rapide pour préparer votre visite.</p>
              <a class="btn-primary da-btn da-btn-primary contact-cta mt-auto" href={siteData.common.phoneHref}>Appeler</a>
            </article>
          )}

          {hasEmail && (
            <article class="reveal contact-card da-panel">
              <p class="card-label">Email</p>
              <p class="card-value email-value">{siteData.common.email}</p>
              <p class="card-copy">Idéal pour une demande détaillée.</p>
              <a class="anchor-link da-btn da-btn-secondary contact-cta mt-auto" href={`mailto:${siteData.common.email}`}>Envoyer un email</a>
            </article>
          )}

          {hasAddress && (
            <article class="reveal contact-card da-panel card-address">
              <p class="card-label">Adresse</p>
              <p class="card-value address-value">{siteData.common.address}</p>
              <p class="card-copy">Accès direct depuis Google Maps.</p>
              <a class="anchor-link da-btn da-btn-secondary contact-cta mt-auto" href={itineraryUrl} target="_blank" rel="noopener noreferrer">
                Ouvrir l'itinéraire
              </a>
            </article>
          )}
        </div>

        {!hasAddress && !hasPhone && !hasEmail && (
          <p class="contact-fallback">Les informations détaillées seront ajoutées après validation client.</p>
        )}

        {(hasInstagram || hasFacebook) && (
          <section class="reveal social-block" aria-labelledby="contact-social-title">
            <h2 id="contact-social-title" class="social-title">Rester connecté</h2>
            <ul class="social-list">
              {hasInstagram && (
                <li>
                  <a class="anchor-link da-btn da-btn-secondary contact-cta social-link" href={siteData.common.social.instagramUrl} target="_blank" rel="noopener noreferrer">
                    <span class="social-link__icon" aria-hidden="true">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="3" width="18" height="18" rx="5" ry="5"></rect>
                        <circle cx="12" cy="12" r="4"></circle>
                        <circle cx="17.5" cy="6.5" r="0.8" fill="currentColor" stroke="none"></circle>
                      </svg>
                    </span>
                    <span class="social-link__text">Instagram · {siteData.common.social.instagramLabel}</span>
                  </a>
                </li>
              )}
              {hasFacebook && (
                <li>
                  <a class="anchor-link da-btn da-btn-secondary contact-cta social-link" href={siteData.common.social.facebookUrl} target="_blank" rel="noopener noreferrer">
                    <span class="social-link__icon" aria-hidden="true">
                      <svg viewBox="0 0 24 24" fill="currentColor">
                        <path d="M13.5 22v-8h2.7l.5-3h-3.2V9.1c0-.9.3-1.5 1.6-1.5h1.8V4.8c-.3 0-1.4-.1-2.7-.1-2.7 0-4.5 1.6-4.5 4.6V11H7.5v3h2.7v8h3.3Z" />
                      </svg>
                    </span>
                    <span class="social-link__text">Facebook · {siteData.common.social.facebookLabel}</span>
                  </a>
                </li>
              )}
            </ul>
          </section>
        )}
      </section>

      {hasAddress && (
        <section class="section-shell da-panel reveal contact-map" aria-labelledby="contact-location-title">
          <div class="map-head">
            <div>
              <h2 id="contact-location-title" class="section-title map-title">Localisation</h2>
              <p class="section-copy mt-2 max-w-3xl">Retrouvez facilement la boutique et ouvrez votre itinéraire en un clic.</p>
            </div>
            <a class="btn-primary da-btn da-btn-primary contact-cta" href={itineraryUrl} target="_blank" rel="noopener noreferrer">Itinéraire</a>
          </div>

          <div class="da-panel mt-5 overflow-hidden border">
            <iframe
              src={embeddedMapUrl}
              title="Carte Maison Patine"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              class="h-72 w-full border-0 md:h-96"
            ></iframe>
          </div>
        </section>
      )}
    </div>
  </main>

  <style>
    .contact-page {
      font-family: var(--font-body);
      color: #2b2018;
      position: relative;
    }

    .contact-page::before {
      content: "";
      position: absolute;
      inset: 0;
      z-index: -1;
      background: radial-gradient(circle at 8% 12%, rgba(176, 139, 87, 0.16), transparent 34%);
    }

    .contact-page::after {
      content: "";
      position: absolute;
      inset: 0;
      z-index: -1;
      pointer-events: none;
      background: radial-gradient(circle at 90% 78%, rgba(109, 125, 100, 0.14), transparent 32%);
    }

    .contact-page h1,
    .contact-page h2,
    .contact-page h3 {
      font-family: var(--font-display);
      font-weight: 500;
      line-height: 1.15;
      letter-spacing: 0.01em;
    }

    .contact-page p,
    .contact-page li,
    .contact-page dd,
    .contact-page dt,
    .contact-page a {
      font-family: var(--font-body);
    }

    .contact-page .section-title {
      font-weight: 500;
    }

    .contact-grid {
      display: grid;
      gap: 1.5rem;
    }

    .contact-grid.has-map {
      grid-template-columns: minmax(0, 1fr);
    }

    .contact-kicker {
      color: #6b5a4b;
      margin-bottom: 0.6rem;
    }

    .contact-page .da-ornament {
      margin-bottom: 0.95rem;
    }

    .contact-title {
      font-size: clamp(2.6rem, 7vw, 4.3rem);
      line-height: 1.08;
      margin-top: 0.2rem;
    }

    .contact-intro {
      color: #2b2018;
      font-size: clamp(1.03rem, 1.5vw, 1.12rem);
      line-height: 1.72;
      margin-top: 1rem;
      max-width: 60ch;
    }

    .open-status {
      margin-top: 0.9rem;
      font-size: 0.8rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--brand-soft);
      font-weight: 600;
    }

    .local-proof {
      margin-top: 0.35rem;
      color: #6b5a4b;
      font-size: 0.95rem;
      max-width: 56ch;
    }

    .contact-cards {
      display: grid;
      gap: 1rem;
      margin-top: 1.8rem;
      grid-template-columns: minmax(0, 1fr);
    }

    .contact-fallback {
      margin-top: 1.5rem;
      color: #6b5a4b;
      max-width: 60ch;
    }

    .contact-card {
      display: flex;
      min-height: 13rem;
      flex-direction: column;
      padding: 1.2rem;
      transition: border-color 280ms ease, background-color 280ms ease, transform 280ms ease, box-shadow 280ms ease;
      box-shadow: 0 8px 16px rgba(43, 32, 24, 0.06);
    }

    .card-label {
      color: #6b5a4b;
      font-size: 0.72rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }

    .card-value {
      margin-top: 0.45rem;
      color: #2b2018;
      font-size: 1.07rem;
      font-weight: 500;
      line-height: 1.35;
    }

    .phone-value,
    .email-value {
      white-space: normal;
      overflow: hidden;
      text-overflow: ellipsis;
      overflow-wrap: anywhere;
    }

    .address-value {
      white-space: normal;
    }

    .card-copy {
      color: #6b5a4b;
      font-size: 0.9rem;
      line-height: 1.72;
      margin-top: 0.45rem;
      margin-bottom: 1rem;
    }

    .social-block {
      margin-top: 2.1rem;
      border-top: 1px solid rgba(107, 90, 75, 0.2);
      padding-top: 1.2rem;
    }

    .social-title {
      font-size: clamp(1.7rem, 2.8vw, 2.2rem);
    }

    .social-list {
      margin-top: 0.9rem;
      display: flex;
      flex-wrap: wrap;
      gap: 0.7rem;
    }

    .social-link {
      display: inline-flex;
      align-items: center;
      gap: 0.58rem;
      min-height: 46px;
      padding-inline: 1rem 1.2rem;
    }

    .social-link__icon {
      width: 1.05rem;
      height: 1.05rem;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      flex: none;
    }

    .social-link__icon svg {
      width: 100%;
      height: 100%;
    }

    .social-link__text {
      line-height: 1.15;
      text-transform: none;
      letter-spacing: 0.02em;
      font-size: 0.86rem;
      font-weight: 500;
    }

    .contact-map {
      align-self: start;
    }

    .map-head {
      display: flex;
      flex-wrap: wrap;
      align-items: end;
      justify-content: space-between;
      gap: 0.8rem;
    }

    .map-title {
      font-size: clamp(2rem, 4vw, 2.95rem);
      line-height: 1.14;
    }

    .da-star {
      width: 1.6rem;
      height: 1.6rem;
      background-image: url("/images/logo.png");
      background-repeat: no-repeat;
      background-position: center;
      background-size: contain;
      line-height: 1;
      opacity: 0.85;
      margin-top: 0.9rem;
      filter: saturate(0.6) sepia(0.3);
    }

    .da-panel {
      border-radius: 2px;
      border-color: rgba(107, 90, 75, 0.28);
      background-color: color-mix(in srgb, #f8f2e8 88%, #fff 12%);
      box-shadow: none;
    }

    .contact-card:hover {
      border-color: rgba(139, 47, 47, 0.38);
      background-color: #fbf5ec;
      transform: translateY(-2px);
      box-shadow: 0 12px 22px rgba(43, 32, 24, 0.1);
    }

    .da-btn {
      border-radius: 2px;
      padding: 0.95rem 1.35rem;
      font-size: 0.73rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      font-weight: 500;
      box-shadow: none;
      line-height: 1;
      font-family: var(--font-body);
    }

    .da-btn-primary {
      background-color: #8b2f2f;
      color: #f4efe6;
    }

    .da-btn-primary:hover {
      background-color: #5e1f1f;
    }

    .da-btn-secondary {
      background-color: transparent;
      border: 1px solid #8b2f2f;
      color: #2b2018;
    }

    .da-btn-secondary:hover {
      background-color: rgba(139, 47, 47, 0.08);
    }

    .da-btn:focus-visible {
      outline: 1px solid #5e1f1f;
      outline-offset: 2px;
    }

    .contact-cta {
      transition: background-color 300ms ease, border-color 300ms ease, color 300ms ease;
    }

    .contact-cta:hover {
      filter: none;
      box-shadow: none;
    }

    @media (min-width: 768px) {
      .contact-cards {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .card-address {
        grid-column: span 2;
      }
    }

    @media (min-width: 1280px) {
      .contact-grid.has-map {
        grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
        align-items: start;
      }

      .contact-map {
        position: sticky;
        top: 1.5rem;
      }
    }

    @media (max-width: 767px) {
      .phone-value,
      .email-value {
        white-space: normal;
        overflow-wrap: anywhere;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .contact-card,
      .contact-card:hover,
      .contact-cta,
      .contact-cta:hover {
        opacity: 1;
        transform: none;
        transition: none;
      }
    }
  </style>
</MainLayout>
